# Port for the server to listen on
PORT=5000

# Connection string to your MongoDB (local or MongoDB Atlas)
# Example: mongodb+srv://username:password@cluster.mongodb.net/portfolio?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017/portfolio

# Allowed CORS origin (production URL of your frontend)
# Example: https://myportfolio.vercel.app
FRONTEND_URL=http://localhost:5173
